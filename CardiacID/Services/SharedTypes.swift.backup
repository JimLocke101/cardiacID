//
//  SharedTypes.swift
//  HeartID Mobile
//
//  Consolidated type definitions to resolve ambiguous type lookup errors
//

import Foundation

// MARK: - Device Types (Consolidated)

public enum DeviceType: String, Codable, CaseIterable {
    case smartphone = "smartphone"
    case smartwatch = "smartwatch"
    case iPhone = "iPhone"
    case appleWatch = "appleWatch"
    case bluetoothLock = "bluetoothLock"
    case bluetoothDoorLock = "bluetoothDoorLock"
    case nfcReader = "nfc_reader"
    case nfcTag = "nfcTag"
    case bluetoothBeacon = "bluetooth_beacon"
    case doorLock = "door_lock"
    case accessPoint = "access_point"
    case sensor = "sensor"
    case camera = "camera"
    case tablet = "tablet"
    case laptop = "laptop"
    case desktop = "desktop"
    case enterpriseDevice = "enterpriseDevice"
    case heartID = "heartID"
    case other = "other"
    
    public var displayName: String {
        switch self {
        case .smartphone: return "Smartphone"
        case .smartwatch: return "Smart Watch"
        case .iPhone: return "iPhone"
        case .appleWatch: return "Apple Watch"
        case .bluetoothLock: return "Bluetooth Lock"
        case .bluetoothDoorLock: return "Bluetooth Door Lock"
        case .nfcReader: return "NFC Reader"
        case .nfcTag: return "NFC Tag"
        case .bluetoothBeacon: return "Bluetooth Beacon"
        case .doorLock: return "Smart Door Lock"
        case .accessPoint: return "Access Point"
        case .sensor: return "Sensor"
        case .camera: return "Camera"
        case .tablet: return "Tablet"
        case .laptop: return "Laptop"
        case .desktop: return "Desktop"
        case .enterpriseDevice: return "Enterprise Device"
        case .heartID: return "HeartID Device"
        case .other: return "Other"
        }
    }
    
    public var icon: String {
        switch self {
        case .smartphone: return "iphone"
        case .smartwatch: return "applewatch"
        case .iPhone: return "iphone"
        case .appleWatch: return "applewatch"
        case .bluetoothLock: return "lock.bluetooth"
        case .bluetoothDoorLock: return "lock.fill"
        case .nfcReader: return "wave.3.right"
        case .nfcTag: return "wave.3.right"
        case .bluetoothBeacon: return "bluetooth"
        case .doorLock: return "lock.fill"
        case .accessPoint: return "wifi"
        case .sensor: return "sensor.tag.radiowaves.forward.fill"
        case .camera: return "camera.fill"
        case .tablet: return "ipad"
        case .laptop: return "laptopcomputer"
        case .desktop: return "desktopcomputer"
        case .enterpriseDevice: return "building.2.crop.circle"
        case .heartID: return "heart.fill"
        case .other: return "questionmark.circle"
        }
    }
}

public enum DeviceStatus: String, Codable, CaseIterable {
    case active = "active"
    case inactive = "inactive"
    case maintenance = "maintenance"
    case error = "error"
    case offline = "offline"
    case pending = "pending"
    case connected = "connected"
    case disconnected = "disconnected" 
    case discovered = "discovered"
    
    public var displayName: String {
        switch self {
        case .active: return "Active"
        case .inactive: return "Inactive"
        case .maintenance: return "Maintenance"
        case .error: return "Error"
        case .offline: return "Offline"
        case .pending: return "Pending"
        case .connected: return "Connected"
        case .disconnected: return "Disconnected"
        case .discovered: return "Discovered"
        }
    }
    
    public var color: String {
        switch self {
        case .active: return "green"
        case .inactive: return "gray"
        case .maintenance: return "orange"
        case .error: return "red"
        case .offline: return "red"
        case .pending: return "yellow"
        case .connected: return "green"
        case .disconnected: return "red"
        case .discovered: return "blue"
        }
    }
}

